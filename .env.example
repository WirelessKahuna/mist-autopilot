# Mist Autopilot — Environment Configuration
# Copy this file to .env and fill in your values
# Never commit .env to Git

# ----------------------------
# Mist API Configuration
# ----------------------------

# Your Mist org API token (from Mist Dashboard > My Account > API Token)
MIST_API_TOKEN=your_api_token_here

# Mist API base URL — change only if using EU or other regional cloud
# Global:  https://api.mist.com
# Europe:  https://api.eu.mist.com
# GCPUS:   https://api.gc1.mist.com
MIST_API_BASE_URL=https://api.mist.com

# Your Mist Org ID (from Mist Dashboard URL or Organization > Settings)
MIST_ORG_ID=your_org_id_here

# ----------------------------
# Application Settings
# ----------------------------

# How long to cache API responses in seconds (default: 300 = 5 minutes)
CACHE_TTL_SECONDS=300

# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
